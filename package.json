{
  "name": "col-browser",
  "version": "2.0.0-rc.5",
  "description": "Catalogue of Life browse and search React components",
  "main": "umd/col-browser.js",
  "module": "es/index.js",
  "exports": {
    ".": {
      "import": "./es/index.js",
      "require": "./umd/col-browser.js"
    }
  },
  "files": [
    "es",
    "umd"
  ],
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "build:umd": "vite build --config vite.config.umd.js && node scripts/minify.js",
    "build:demo": "vite build --config vite.config.demo.js",
    "build:all": "npm run build && npm run build:umd",
    "prepublishOnly": "npm run build:all",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "test:watch": "vitest"
  },
  "dependencies": {
    "antd": "^6.4.3",
    "axios": "^1.16.1",
    "btoa": "^1.2.1",
    "dataloader": "^2.2.3",
    "dayjs": "^1.11.13",
    "dompurify": "^3.4.6",
    "highcharts": "^12.6.0",
    "highcharts-react-official": "^3.2.3",
    "history": "^5.3.0",
    "linkify-html": "^4.3.3",
    "linkifyjs": "^4.3.3",
    "lodash": ">=4.17.21",
    "marked": "^18.0.4",
    "query-string": "^9.3.1",
    "react-highlight-words": "^0.21.0",
    "react-jss": "^10.10.0",
    "react-router-dom": "^7.15.1"
  },
  "peerDependencies": {
    "maplibre-gl": "^4.7.0 || ^5.0.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0"
  },
  "devDependencies": {
    "jsdom": "^29.1.1",
    "less": "^4.2.0",
    "maplibre-gl": "^5.0.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "terser": "^5.48.0",
    "vite": "^6.4.2",
    "vitest": "^3.2.4"
  },
  "author": "",
  "homepage": "",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/CatalogueOfLife/portal-components.git"
  },
  "keywords": [
    "react-component",
    "taxonomy",
    "catalogue of life"
  ]
}
